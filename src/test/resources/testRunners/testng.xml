<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" verbose="4" thread-count = "3" parallel = "tests">
  <listeners>
  	<listener class-name="com.aventstack.chaintest.plugins.ChainTestListener"></listener>
  </listeners>
  <test name="Login Test">
  	<parameter name = "browser" value = "chrome"></parameter>
    <classes>
      <class name="com.qa.google.tests.LoginPageTest"/>
    </classes>
  </test> <!-- Test -->
  
  <test name="Accounts Test">
  	<parameter name = "browser" value = "edge"></parameter>
    <classes>
      <class name="com.qa.google.tests.AccountsPageTest"/>
    </classes>
  </test>
  
 
</suite> <!-- Suite -->
